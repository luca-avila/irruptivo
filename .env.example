# Public app URL used for Mercado Pago return URLs and guest order links.
IRRUPTIVO_APP_URL=http://localhost:3000

# Public contact links shown in storefront, payment, and order-status feedback.
NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/5490000000000
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/irruptivo

# Admin access. ADMIN_SESSION_SECRET must be at least 32 characters.
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=replace-with-at-least-32-characters
# ADMIN_SESSION_DURATION_SECONDS=28800

# Mercado Pago checkout and webhook reconciliation.
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
# MERCADO_PAGO_NOTIFICATION_URL=https://example.com/api/mercado-pago/webhook
# MERCADO_PAGO_API_BASE_URL=https://api.mercadopago.com

# Uploaded product media root. Defaults to /var/lib/irruptivo/media.
# IRRUPTIVO_MEDIA_ROOT=/var/lib/irruptivo/media

# Provider-agnostic transactional email adapter.
# Development can omit these values to use the local outbox fallback.
# For production, connect the chosen HTTP-compatible provider here.
# IRRUPTIVO_EMAIL_PROVIDER=http
# IRRUPTIVO_EMAIL_PROVIDER_URL=
# IRRUPTIVO_EMAIL_PROVIDER_TOKEN=
# IRRUPTIVO_EMAIL_FROM_EMAIL=
# IRRUPTIVO_EMAIL_FROM_NAME=Irruptivo
